ents/Common/MemberPage';\n\ninterface Props { tenantName: string; tenantSlug: string; member?: any; demo: any; }\n\nconst GalleryPage: React.FC<Props> = ({ tenantName, tenantSlug, member, demo }) => (\n    <MemberPage title=\"Galeri & Album\" parentLabel=\"Konten\">\n        <PremiumGallery gallery={demo.gallery} />\n    </MemberPage>\n);\n\n(GalleryPage as any).layout = (page: React.ReactNode) => <TenantMemberLayout>{page}</TenantMemberLayout>;\n\nexport default GalleryPage;\n","usedDeprecatedRules":[]},{"filePath":"/var/www/html/apps/family2/project/resources/js/Pages/Tenant/Frontend/Member/Games.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'Container' is defined but never used.","line":2,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":2,"endColumn":19,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Container"},"fix":{"range":[50,60],"text":""},"desc":"Remove unused variable \"Container\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'Badge' is defined but never used.","line":2,"column":37,"nodeType":"Identifier","messageId":"unusedVar","endLine":2,"endColumn":42,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Badge"},"fix":{"range":[75,82],"text":""},"desc":"Remove unused variable \"Badge\"."}]},{"ruleId":"import/order","severity":1,"message":"`../../../../Components/Common/MemberPage` import should occur before import of `../../../../Layouts/TenantMemberLayout`","line":5,"column":1,"nodeType":"ImportDeclaration","endLine":5,"endColumn":67,"fix":{"range":[110,250],"text":"import MemberPage from '../../../../Components/Common/MemberPage';\nimport TenantMemberLayout from '../../../../Layouts/TenantMemberLayout';\n"}},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'tenantName' is defined but never used. Allowed unused args must match /^_/u.","line":9,"column":39,"nodeType":"Identifier","messageId":"unusedVar","endLine":9,"endColumn":49},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'tenantSlug' is defined but never used. Allowed unused args must match /^_/u.","line":9,"column":51,"nodeType":"Identifier","messageId":"unusedVar","endLine":9,"endColumn":61},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'member' is defined but never used. Allowed unused args must match /^_/u.","line":9,"column":63,"nodeType":"Identifier","messageId":"unusedVar","endLine":9,"endColumn":69},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'demo' is defined but never used. Allowed unused args must match /^_/u.","line":9,"column":71,"nodeType":"Identifier","messageId":"unusedVar","endLine":9,"endColumn":75},{"ruleId":"react-hooks/purity","severity":2,"message":"Error: Cannot call impure function during render\n\n`Math.random` is an impure function. Calling an impure function can produce unstable results that update unpredictably when the component happens to re-render. (https://react.dev/reference/rules/components-and-hooks-must-be-pure#components-and-hooks-must-be-idempotent).\n\n/var/www/html/apps/family2/project/resources/js/Pages/Tenant/Frontend/Member/Games.tsx:11:42\n   9 | const GamesPage: React.FC<Props> = ({ tenantName, tenantSlug, member, demo }) => {\n  10 |     // Game logic for \"Tebak Angka\" (example)\n> 11 |     const [target] = useState(Math.floor(Math.random() * 10) + 1);\n     |                                          ^^^^^^^^^^^^^ Cannot call impure function\n  12 |     const [guess, setGuess] = useState('');\n  13 |     const [msg, setMsg] = useState('Tebak angka 1-10');\n  14 |","line":11,"column":42,"nodeType":null,"endLine":11,"endColumn":55}],"suppressedMessages":[],"errorCount":7,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":1,"source":"import React, { useState } from 'react';\nimport { Container, Row, Col, Card, Badge } from 'react-bootstrap';\n\nimport TenantMemberLayout from '../../../../Layouts/TenantMemberLayout';\nimport MemberPage from '../../../../Components/Common/MemberPage';\n\ninterface Props { tenantName: string; tenantSlug: string; member?: any; demo: any; }\n\nconst GamesPage: React.FC<Props> = ({ tenantName, tenantSlug, member, demo }) => {\n    // Game logic for \"Tebak Angka\" (example)\n    const [target] = useState(Math.floor(Math.random() * 10) + 1);\n    const [guess, setGuess] = useState('');\n    const [msg, setMsg] = useState('Tebak angka 1-10');\n\n    const handleGuess = () => {\n        const n = parseInt(guess);\n        if (n === target) setMsg('🎉 Selamat! Anda benar!');\n        else setMsg(n < target ? 'Terlalu rendah!' : 'Terlalu tinggi!');\n    };\n\n    return (\n        <MemberPage title=\"Pusat Game Keluarga\" parentLabel=\"Hiburan\">\n            <Row className=\"g-4\">\n                <Col lg={6}>\n                    <Card className=\"border-0 shadow-sm h-100\">\n                        <Card.Body className=\"text-center p-5\">\n                            <div className=\"rounded-circle bg-info-subtle d-flex align-items-center justify-content-center mx-auto mb-4\"\n                                style={{width:80, height:80}}>\n                                <i className=\"ri-gamepad-line text-info fs-36\"></i>\n                            </div>\n                            <h3 className=\"fw-bold mb-3\">Tebak Angka Keluarga</h3>\n                            <p className=\"text-muted mb-4\">{msg}</p>\n                            <div className=\"d-flex gap-2 justify-content-center mb-3\">\n                                <input type=\"number\" className=\"form-control text-center\" style={{width:80}}\n                                    value={guess} onChange={e => setGuess(e.target.value)} />\n                                <button onClick={handleGuess} className=\"btn btn-info px-4\">Tebak!</button>\n                            </div>\n                            <p className=\"small text-muted mb-0\">Menangkan 10 poin jika benar!</p>\n                        </Card.Body>\n                    </Card>\n                </Col>\n                <Col lg={6}>\n                    <Card className=\"border-0 shadow-sm h-100\">\n                        <Card.Header className=\"bg-transparent border-0 pt-3\">\n                            <h5 className=\"fw-bold mb-0\"><i className=\"ri-medal-line me-2 text-warning\"></i>Status Pemain</h5>\n                        </Card.Header>\n                        <Card.Body>\n                            <div className=\"p-3 bg-light rounded-3 mb-3\">\n                                <h6 className=\"fw-bold mb-1\">Tiket Tersedia</h6>\n                                <div className=\"d-flex align-items-center gap-2\">\n                                    <i className=\"ri-coupon-2-line text-warning fs-20\"></i>\n                                    <span className=\"fw-bold fs-18\">5 Tiket</span>\n                                </div>\n                            </div>\n                            <p className=\"text-muted fs-13 mb-0\">Tiket akan bertambah setiap kali Anda menyelesaikan tugas harian.</p>\n                        </Card.Body>\n                    </Card>\n                </Col>\n            </Row>\n        </MemberPage>\n    );\n};\n\n(GamesPage as any).layout = (page: React.ReactNode) => <TenantMemberLayout>{page}</TenantMemberLayout>;\n\nexport default GamesPage;\n","usedDeprecatedRules":[]},{"filePath":"/var/www/html/apps/family2/project/resources/js/Pages/Tenant/Frontend/Member/Health.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'Container' is defined but never used.","line":2,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":2,"endColumn":19,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"Container"},"fix":{"range":[27,72],"text":""},"desc":"Remove unused import declaration."}]},{"ruleId":"import/order","severity":1,"message":"`../../../../Layouts/TenantMemberLayout` import should occur before import of `../Components/PremiumGrowthTracker`","line":5,"column":1,"nodeType":"ImportDeclaration","endLine":5,"endColumn":73,"fix":{"range":[73,217],"text":"import TenantMemberLayout from '../../../../Layouts/TenantMemberLayout';\nimport PremiumGrowthTracker from '../Components/PremiumGrowthTracker';\n"}},{"ruleId":"import/order","severity":1,"message":"`../../../../Components/Common/MemberPage` import should occur before import of `../Components/PremiumGrowthTracker`","line":6,"column":1,"nodeType":"ImportDeclaration","endLine":6,"endColumn":67,"fix":{"range":[73,284],"text":"import MemberPage from '../../../../Components/Common/MemberPage';\nimport PremiumGrowthTracker from '../Components/PremiumGrowthTracker';\nimport TenantMemberLayout from '../../../../Layouts/TenantMemberLayout';\n"}},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'tenantName' is defined but never used. Allowed unused args must match /^_/u.","line":10,"column":40,"nodeType":"Identifier","messageId":"unusedVar","endLine":10,"endColumn":50},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'tenantSlug' is defined but never used. Allowed unused args must match /^_/u.","line":10,"column":52,"nodeType":"Identifier","messageId":"unusedVar","endLine":10,"endColumn":62},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'member' is defined but never used. Allowed unused args must match /^_/u.","line":10,"column":64,"nodeType":"Identifier","messageId":"unusedVar","endLine":10,"endColumn":70}],"suppressedMessages":[],"errorCount":4,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":2,"source":"import React from 'react';\nimport { Container } from 'react-bootstrap';\n\nimport PremiumGrowthTracker from '../Components/PremiumGrowthTracker';\nimport TenantMemberLayout from '../../../../Layouts/TenantMemberLayout';\nimport MemberPage from '../../../../Components/Common/MemberPage';\n\ninterface Props { tenantName: string; tenantSlug: string; member?: any; demo: any; }\n\nconst HealthPage: React.FC<Props> = ({ tenantName, tenantSlug, member, demo }) => (\n    <MemberPage title=\"Kesehatan Keluarga\" parentLabel=\"Kesehatan & Catatan\">\n        <PremiumGrowthTracker growth_tracker={demo.growth_tracker} />\n    </MemberPage>\n);\n\n(HealthPage as any).layout = (page: React.ReactNode) => <TenantMemberLayout>{page}</TenantMemberLayout>;\n\nexport default HealthPage;\n","usedDeprecatedRules":[]},{"filePath":"/var/www/html/apps/family2/project/resources/js/Pages/Tenant/Frontend/Member/Hub.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'Head' is defined but never used.","line":1,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":1,"endColumn":14,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Head"},"fix":{"range":[9,14],"text":""},"desc":"Remove unused variable \"Head\"."}]},{"ruleId":"import/order","severity":1,"message":"`../../../../Components/Common/MemberPage` import should occur before import of `../../../../Layouts/TenantMemberLayout`","line":6,"column":1,"nodeType":"ImportDeclaration","endLine":6,"endColumn":67,"fix":{"range":[132,272],"text":"import MemberPage from '../../../../Components/Common/MemberPage';\nimport TenantMemberLayout from '../../../../Layouts/TenantMemberLayout';\n"}},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'tenantSlug' is defined but never used. Allowed unused args must match /^_/u.","line":15,"column":45,"nodeType":"Identifier","messageId":"unusedVar","endLine":15,"endColumn":55}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":1,"source":"import { Head, Link } from '@inertiajs/react';\nimport React from 'react';\nimport { Row, Col, Card, Badge } from 'react-bootstrap';\n\nimport TenantMemberLayout from '../../../../Layouts/TenantMemberLayout';\nimport MemberPage from '../../../../Components/Common/MemberPage';\n\ninterface Props {\n    tenantName: string;\n    tenantSlug: string;\n    member?: { user?: { name?: string } };\n    demo: any;\n}\n\nconst Hub: React.FC<Props> = ({ tenantName, tenantSlug, member, demo }) => {\n    const memberName = member?.user?.name ?? 'Anggota';\n    const hour = new Date().getHours();\n    const greeting = hour < 11 ? 'Selamat Pagi' : hour < 15 ? 'Selamat Siang' : hour < 18 ? 'Selamat Sore' : 'Selamat Malam';\n\n    const totalPoints = (demo?.leaderboard || []).reduce((s: number, l: any) => s + (l.points || 0), 0);\n\n    const modules = [\n        { label: 'Kalender', desc: 'Jadwal & agenda', icon: 'ri-calendar-2-line', color: 'primary', href: '/calendar' },\n        { label: 'Proyek', desc: 'Papan proyek Kanban', icon: 'ri-kanban-view', color: 'warning', href: '/projects' },\n        { label: 'Tugas', desc: 'Rutinitas & to-do', icon: 'ri-checkbox-multiple-line', color: 'success', href: '/tasks' },\n        { label: 'Reward', desc: 'Toko hadiah & poin', icon: 'ri-trophy-line', color: 'warning', href: '/rewards' },\n        { label: 'Dompet Anak', desc: 'Saldo poin per anak', icon: 'ri-wallet-3-line', color: 'info', href: '/wallet' },\n        { label: 'Keuangan', desc: 'Pemasukan & pengeluaran', icon: 'ri-money-dollar-circle-line', color: 'success', href: '/finance' },\n        { label: 'Meal Planner', desc: 'Menu & belanja', icon: 'ri-restaurant-2-line', color: 'danger', href: '/kitchen' },\n        { label: 'Growth Tracker', desc: 'Tumbuh kembang anak', icon: 'ri-seedling-line', color: 'success', href: '/health' },\n        { label: 'Rekam Medis', desc: 'Imunisasi & dokumen', icon: 'ri-medicine-bottle-line', color: 'danger', href: '/medical' },\n        { label: 'Inventaris', desc: 'Aset & info rumah', icon: 'ri-home-gear-line', color: 'primary', href: '/assets' },\n        { label: 'Wishlist', desc: 'Wisata & kuliner impian', icon: 'ri-heart-3-line', color: 'danger', href: '/leisure' },\n        { label: 'Vacation', desc: 'Itinerary & packing', icon: 'ri-suitcase-3-line', color: 'primary', href: '/vacation' },\n        { label: 'Game Center', desc: 'Mini-games keluarga', icon: 'ri-gamepad-line', color: 'info', href: '/games' },\n        { label: 'WhatsApp', desc: 'WA bot & perintah', icon: 'ri-whatsapp-line', color: 'success', href: '/whatsapp' },\n        { label: 'Galeri', desc: 'Album foto keluarga', icon: 'ri-image-line', color: 'info', href: '/gallery' },\n        { label: 'Blog', desc: 'Wisata & parenting', icon: 'ri-article-line', color: 'success', href: '/blog' },\n        { label: 'File Manager', desc: 'Dokumen penting', icon: 'ri-folder-3-line', color: 'warning', href: '/files' },\n    ];\n\n    return (\n        <MemberPage title=\"Member Hub\" parentLabel=\"Dashboard\">\n            <div className=\"mb-4\">\n                <Card className=\"border-0 shadow-sm overflow-hidden\">\n                    <Card.Body className=\"p-0\">\n                        <div className=\"p-4\" style={{ background: 'linear-gradient(135deg, var(--vz-primary) 0%, #405189 100%)' }}>\n                            <Row className=\"align-items-center g-4\">\n                                <Col lg={8}>\n                                    <h3 className=\"text-white fw-bold mb-2\">{greeting}, {memberName}! 👋</h3>\n                                    <p className=\"text-white-50 mb-0\">\n                                        Selamat datang kembali di keluarga <strong className=\"text-white\">{tenantName}</strong>. \n                                        Semua modul manajemen rumah tangga Anda siap diakses melalui menu atau shortcut di bawah.\n                                    </p>\n                                </Col>\n                                <Col lg={4} className=\"text-lg-end\">\n                                    <div className=\"d-inline-flex align-items-center gap-3\">\n                                        <div className=\"text-center bg-white bg-opacity-10 px-3 py-2 rounded-3 border border-white border-opacity-10\">\n                                            <div className=\"text-white fw-bold fs-16\">{totalPoints.toLocaleString()}</div>\n                                            <div className=\"text-white-50 fs-11\">Poin Keluarga</div>\n                                        </div>\n                                        <div className=\"text-center bg-white bg-opacity-10 px-3 py-2 rounded-3 border border-white border-opacity-10\">\n                                            <div className=\"text-white fw-bold fs-16\">{(demo?.projects || []).length}</div>\n                                            <div className=\"text-white-50 fs-11\">Proyek Aktif</div>\n                                        </div>\n                                    </div>\n                                </Col>\n                            </Row>\n                        </div>\n                    </Card.Body>\n                </Card>\n            </div>\n\n            <section className=\"section py-3\">\n                <h5 className=\"fw-bold mb-4\">Semua Modul ({modules.length})</h5>\n                <Row className=\"g-3\">\n                    {(demo?.modules || modules).map((mod: any, i: number) => (\n                        <Col xs={6} sm={4} md={3} lg={2} key={i}>\n                            <Link href={mod.href} className=\"text-decoration-none\">\n                                <Card className=\"border h-100\"\n                                    style={{ transition: 'transform 0.2s, box-shadow 0.2s', cursor: 'pointer' }}\n                                    onMouseEnter={e => {\n                                        const el = e.currentTarget as HTMLElement;\n                                        el.style.transform = 'translateY(-4px)';\n                                        el.style.boxShadow = '0 8px 24px rgba(0,0,0,0.1)';\n                                    }}\n                                    onMouseLeave={e => {\n                                        const el = e.currentTarget as HTMLElement;\n                                        el.style.transform = '';\n                                        el.style.boxShadow = '';\n                                    }}>\n                                <Card.Body className=\"p-3 text-center\">\n                                    <div className={`rounded-3 mx-auto d-flex align-items-center justify-content-center mb-2 bg-${mod.color}-subtle`}\n                                        style={{ width: 48, height: 48 }}>\n                                        <i className={`${mod.icon} text-${mod.color} fs-20`}></i>\n                                    </div>\n                                    <h6 className=\"fw-semibold mb-0 fs-13\">{mod.label}</h6>\n                                    <p className=\"text-muted fs-11 mb-0 mt-1\">{mod.desc}</p>\n                                </Card.Body>\n                                </Card>\n                            </Link>\n                        </Col>\n                    ))}\n                </Row>\n            </section>\n\n            <section className=\"section bg-light py-4\">\n                <Row className=\"g-4\">\n                    <Col lg={4}>\n                        <Card className=\"border-0 shadow-sm h-100\">\n                            <Card.Header className=\"bg-transparent border-0 pt-3 pb-0 d-flex justify-content-between align-items-center\">\n                                <h6 className=\"fw-bold mb-0\"><i className=\"ri-calendar-todo-line text-primary me-2\"></i>Agenda Mendatang</h6>\n                                <Link href=\"/calendar\" className=\"btn btn-soft-primary btn-sm\">Lihat Semua</Link>\n                            </Card.Header>\n                            <Card.Body className=\"pt-2\">\n                                {(demo?.calendar || []).map((e: an